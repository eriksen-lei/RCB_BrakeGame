{
  "name": "racing-game-rcb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "app:dev": "electron .",
    "app:pack": "node scripts/package-electron.cjs",
    "app:dist": "node scripts/package-electron.cjs",
    "app:builder:pack": "electron-builder --dir --publish never",
    "app:builder:dist": "electron-builder --win --publish never",
    "app:builder:mac": "electron-builder --mac zip --arm64 --publish never"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "~5.8.0",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.rcb.brakeracing",
    "productName": "RCB Brake Racing",
    "npmRebuild": false,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "prototype-trackbeta.html",
      "Resources/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
